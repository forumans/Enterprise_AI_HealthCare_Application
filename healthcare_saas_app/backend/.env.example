# Healthcare Application Backend Environment Variables
# Copy this file to .env and update with your actual values.
#
# DEPLOYMENT MODES
# ─────────────────────────────────────────────────────────────
# Local (Uvicorn):        set HOST, PORT, and all vars below.
#                         Set DB_SCHEMA_INIT_ON_STARTUP=true to auto-create tables.
# Lambda + API Gateway:   HOST and PORT are ignored by Lambda (safe to omit).
#                         Set DB_SCHEMA_INIT_ON_STARTUP=false — run migrations
#                         separately via the migrations/ scripts.
#                         Set S3_BUCKET_NAME for document uploads.
#                         All secrets are passed as Lambda environment variables
#                         via SAM parameter overrides at deploy time.

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://username:password@your-rds-endpoint:5432/healthcare_db
# Set false in Lambda/production; use migrations/ scripts to manage schema.
DB_SCHEMA_INIT_ON_STARTUP=false

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

# ── CORS (comma-separated allowed origins) ────────────────────
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Server (local only — not used by Lambda) ─────────────────
HOST=0.0.0.0
PORT=8000

# ── S3 (required for Lambda document uploads) ─────────────────
# Create a private S3 bucket and set its name here.
# IAM role attached to the Lambda function must have s3:PutObject
# and s3:GetObject permissions on this bucket.
S3_BUCKET_NAME=your-healthcare-documents-bucket

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Email (optional — password reset / notifications) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# ── Misc ──────────────────────────────────────────────────────
APP_ENV=production
MAX_UPLOAD_SIZE=10485760
